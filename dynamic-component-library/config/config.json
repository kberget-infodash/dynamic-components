{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "dynamic-component-library": {
      "components": [
        {
          "entrypoint": "./lib/index.js",
          "manifest": "./src/libraries/components/ComponentsLibrary.manifest.json"
        }
      ]
    }
  },
  "externals": {
    "react": "React",
    "react-dom": "ReactDOM"
  },
  "localizedResources": {
    "ComponentLibraryLibraryStrings": "lib/libraries/components/loc/{locale}.js"
  }
}
